# MongoDB Configuration
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=smart-sentinel

# Server Configuration
PORT=5000

# Firebase Configuration
FIREBASE_DATABASE_URL=your-database-url
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# OR use service account JSON (preferred)
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'

# JWT Configuration (if needed)
JWT_SECRET=your-secret-key-here

# Instructions:
# 1. Download Firebase service account JSON from Firebase Console
# 2. Either:
#    a) Set FIREBASE_SERVICE_ACCOUNT with the entire JSON (stringify it)
#    b) Or extract individual fields (PROJECT_ID, CLIENT_EMAIL, PRIVATE_KEY)
# 3. Make sure to escape newlines in private key (\\n)
